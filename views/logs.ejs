                                            <%= log.user_name || 'System' %>
                                        </td>
                                        <td>
                                            <%= log.reference_note %>
                                        </td>
                                        <td class="text-center">
                                            <%= log.transaction_date %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="/js/script.js"></script>
</body>
</html>
                                <option value="delete" <%=selectedType=='delete' ? 'selected' : '' %>>
                                    ลบสินค้า
                                </option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary w-100">
                                <i class="bi bi-search"></i>
                                ค้นหา
                            </button>
                        </div>
                    </form>
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered align-middle">
                            <thead class="table-dark text-center">
                                <tr>
                                    <th style="width:80px">ID</th>
                                    <th>สินค้า</th>
                                    <th style="width:150px">ประเภท</th>
                                    <th style="width:100px">จำนวน</th>
                                    <th style="width:180px">ผู้ทำรายการ</th>
                                    <th>รายละเอียด</th>
                                    <th style="width:180px">วันที่</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% logs.forEach(log=> { %>
                                    <tr>
                                        <td class="text-center">
                                            <%= log.transaction_id %>
                                        </td>
                                        <td>
                                            <%= log.product_name || '-' %>
                                        </td>
                                        <td class="text-center">
                                            <% if (log.transaction_type==='receive' ) { %>
                                                <span class="badge bg-success">รับสินค้า</span>
                                                <% } %>
                                            <% if (log.transaction_type==='dispatch' ) { %>
                                                    <span class="badge bg-danger">เบิกสินค้า</span>
                                                <% } %>
                                            <% if (log.transaction_type==='adjust' ) { %>
                                                    <span class="badge bg-warning text-dark">ปรับสต็อก</span>
                                                <% } %>
                                            <% if (log.transaction_type==='add' ) { %>
                                                    <span class="badge bg-primary">เพิ่มสินค้า</span>
                                                <% } %>
